// =============================================
// SECTION 5: Forms and Input Controls
// =============================================

### Forms and Input Controls

::: grid FormsGrid cols=2 gap=24
  ::: card RegistrationFormCard
    ### User Registration
    ::: form RegistrationForm action="/api/register" method=POST
      *required input FullName placeholder="John Doe" :: String
      *required email EmailAddress placeholder="user@example.com" :: Email
      *required password UserPassword placeholder="minimum 8 characters" :: Password
      input PhoneNumber placeholder="+1 (555) 000-0000" :: Phone

      spacer 8

      ::: select Country
        item United States
        item United Kingdom
        item Germany
        item Japan
        item India
        item Australia
      :::

      ::: select Role
        item Developer
        item Designer
        item Product Manager
        item Data Scientist
      :::

      spacer 8
      submit RegisterButton variant=primary: Create Account
    :::
  :::

  ::: card FeedbackFormCard
    ### Feedback Survey
    ::: form FeedbackForm action="/api/feedback" method=POST
      *required email ContactEmail placeholder="your@email.com" :: Email
      input Subject placeholder="Brief description of feedback" :: String

      ::: select Category
        item Bug Report
        item Feature Request
        item Performance Issue
        item Documentation
        item Other
      :::

      ::: select Priority
        item Critical
        item High
        item Medium
        item Low
      :::

      spacer 8
      [x] I agree to the terms of service
      [ ] Subscribe to product newsletter

      spacer 8
      submit SubmitFeedback variant=primary: Send Feedback
      button CancelButton variant=secondary: Cancel
    :::
  :::
:::

