{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Slate Visual Language",
  "scopeName": "source.slate",
  "patterns": [
    {
      "name": "comment.line.double-slash.slate",
      "match": "//.*$"
    },
    {
      "name": "markup.heading.1.slate",
      "match": "^\\s*#\\s+.*$"
    },
    {
      "name": "markup.heading.2.slate",
      "match": "^\\s*##\\s+.*$"
    },
    {
      "name": "markup.heading.3.slate",
      "match": "^\\s*###\\s+.*$"
    },
    {
      "match": "^\\s*(:::)\\s*(\\w+)?(?:\\s+(\\w+))?",
      "captures": {
        "1": { "name": "keyword.control.block.slate" },
        "2": { "name": "support.class.slate" },
        "3": { "name": "entity.name.type.slate" }
      }
    },
    {
      "name": "keyword.control.block.end.slate",
      "match": "^\\s*(:::)\\s*$"
    },
    {
      "name": "keyword.other.slate",
      "match": "\\b(stat|spacer|divider|button|submit|email|input|password|select|item|node|flowchart|flow|form|grid|card|row|section|page)\\b"
    },
    {
      "match": "(\\b[a-zA-Z_-][\\w-]*)\\s*(=|:)\\s*(\"[^\"]*\"|'[^']*')",
      "captures": {
        "1": { "name": "entity.other.attribute-name.slate" },
        "2": { "name": "keyword.operator.assignment.slate" },
        "3": { "name": "string.quoted.slate" }
      }
    },
    {
      "match": "(\\b[a-zA-Z_-][\\w-]*)\\s*(=|:)\\s*([+-]?\\d+(?:\\.\\d+)?%?\\b)",
      "captures": {
        "1": { "name": "entity.other.attribute-name.slate" },
        "2": { "name": "keyword.operator.assignment.slate" },
        "3": { "name": "constant.numeric.slate" }
      }
    },
    {
      "match": "(\\b[a-zA-Z_-][\\w-]*)\\s*(=|:)\\s*([a-zA-Z_#][\\w#-]*)\\b",
      "captures": {
        "1": { "name": "entity.other.attribute-name.slate" },
        "2": { "name": "keyword.operator.assignment.slate" },
        "3": { "name": "variable.other.property.slate" }
      }
    },
    {
      "name": "keyword.operator.relationship.slate",
      "match": "->"
    },
    {
      "match": "\\((circle|rect|diamond|square|ellipse|Triangle)\\)",
      "captures": {
        "1": { "name": "support.type.shape.slate" }
      }
    },
    {
      "match": "(\\*)\\s*(required|readonly|disabled)",
      "captures": {
        "1": { "name": "keyword.operator.validation.slate" },
        "2": { "name": "storage.modifier.slate" }
      }
    },
    {
      "match": "(::)\\s*([a-zA-Z_]\\w*)",
      "captures": {
        "1": { "name": "keyword.operator.type.slate" },
        "2": { "name": "support.type.primitive.slate" }
      }
    },
    {
      "name": "string.quoted.double.slate",
      "begin": "\"",
      "end": "\""
    },
    {
      "name": "string.quoted.single.slate",
      "begin": "'",
      "end": "'"
    },
    {
      "name": "constant.numeric.slate",
      "match": "\\b[+-]?\\d+(\\.\\d+)?%?\\b"
    }
  ]
}
