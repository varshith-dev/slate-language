{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Slate Visual Language",
  "scopeName": "source.slate",
  "patterns": [
    {
      "name": "comment.line.double-slash.slate",
      "match": "//.*$"
    },
    {
      "name": "markup.heading.slate",
      "match": "^\\s*#{1,6}\\s+.*$"
    },
    {
      "name": "keyword.control.block.slate",
      "match": ":::"
    },
    {
      "name": "keyword.other.slate",
      "match": "\\b(stat|spacer|divider|button|submit|email|input|password|select|item|node|flowchart|flow|form|grid|card|row|section|page)\\b"
    },
    {
      "name": "keyword.operator.relationship.slate",
      "match": "->"
    },
    {
      "name": "string.quoted.double.slate",
      "begin": "\"",
      "end": "\""
    },
    {
      "name": "constant.numeric.slate",
      "match": "\\b\\d+(\\.\\d+)?%?\\b"
    }
  ]
}
